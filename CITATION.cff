version: "0.15.5"
date-released: "2026-06-16"
license: MIT
repository-code: "https://github.com/synesis-lang/synesis-lsp"
url: "https://synesis-lang.github.io/synesis-docs"
keywords:
  - qualitative-research
  - knowledge-engineering
  - language-server-protocol
  - lsp
  - vscode
  - synesis
